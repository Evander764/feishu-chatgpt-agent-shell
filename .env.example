# Copy to .env. Never commit .env.

# Server
APP_HOST=127.0.0.1
APP_PORT=18080
PUBLIC_BASE_URL=

# Feishu/Lark Open Platform app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_DOMAIN=https://open.feishu.cn

# If using HTTP callbacks, expose http://127.0.0.1:18080/lark/events via a tunnel.
# Example callback URL: https://your-tunnel.example.com/lark/events

# ChatGPT web wrapper
CHATGPT_PROJECT_URL=
CHATGPT_PROJECT_NAME=
CHATGPT_BROWSER_PROFILE_DIR=~/Library/Application Support/Feishu ChatGPT Agent Shell/browser-profile
CHATGPT_BROWSER_EXECUTABLE=
CHATGPT_CDP_PORT=9227
# visible: for first login/debug; silent: off-screen/minimized with focus restored; headless: no window but some sites may not render correctly.
CHATGPT_RUN_MODE=silent
CHATGPT_CLOSE_AFTER_JOB=true
CHATGPT_WAIT_SECONDS=240
CHATGPT_WEB_EXTRACTION_AUTHORIZED=false

# Generation defaults
DEFAULT_GROUP_COUNT=4
DEFAULT_IMAGES_PER_GROUP=4
MAX_IMAGES_PER_GROUP=5
PARALLEL_TABS=4

# Planner / multimodal API
# OpenAI-compatible Chat Completions endpoint is used for the template.
PLANNER_BASE_URL=https://api.openai.com/v1
PLANNER_API_KEY=
PLANNER_MODEL=gpt-4.1-mini
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=
VISION_MODEL=gpt-4.1-mini

# Storage
DATA_DIR=./data

